{\n  \"name\": \"hairstyle-ai-web-preview\",\n  \"version\": \"1.0.0\",\n  \"type\": \"module\",\n  \"scripts\": {\n    \"dev\": \"vite\",\n    \"build\": \"vite build\",\n    \"preview\": \"vite preview\"\n  },\n  \"dependencies\": {\n    \"react\": \"^18.2.0\",\n    \"react-dom\": \"^18.2.0\",\n    \"framer-motion\": \"^10.16.0\"\n  },\n  \"devDependencies\": {\n    \"@vitejs/plugin-react\": \"^4.0.0\",\n    \"vite\": \"^4.4.0\",\n    \"typescript\": \"^5.1.0\"\n  }\n}\n", "path": "web-preview/package.json"}, {"content": "import React from 'react';\n\nconst COLORS = {\n  background: '#0a0a0a',\n  backgroundSecondary: '#121212',\n  gold: '#d4af37',\n  goldLight: '#e8c547',\n  white: '#ffffff',\n  textSecondary: 'rgba(255, 255, 255, 0.7)',\n  glass: 'rgba(255, 255, 255, 0.08)',\n};\n\ninterface MockScreenProps {\n  title: string;\n  description: string;\n  children: React.ReactNode;\n}\n\nconst MockScreen: React.FC<MockScreenProps> = ({ title, description, children }) => {\n  return (\n    <div\n      style={{\n        backgroundColor: COLORS.background,\n        borderRadius: '24px',\n        overflow: 'hidden',\n        border: `1px solid ${COLORS.gold}`,\n        boxShadow: '0 0 20px rgba(212, 175, 55, 0.2)',\n        maxWidth: '400px',\n        margin: '20px auto',\n        fontFamily: 'system-ui, -apple-system, sans-serif',\n      }}\n    >\n      {/* Header */}\n      <div\n        style={{\n          background: `linear-gradient(135deg, rgba(212, 175, 55, 0.2), rgba(212, 175, 55, 0))`,\n          borderBottom: `1px solid ${COLORS.gold}`,\n          padding: '20px',\n          textAlign: 'center',\n        }}\n      >\n        <h3 style={{ color: COLORS.gold, margin: '0 0 8px 0', fontSize: '16px' }}>\n          {title}\n        </h3>\n        <p style={{ color: COLORS.textSecondary, margin: 0, fontSize: '12px' }}>\n          {description}\n        </p>\n      </div>\n\n      {/* Content */}\n      <div style={{ padding: '24px' }}>{children}</div>\n    </div>\n  );\n};\n\nconst StyleCard: React.FC<{ rank: number; name: string; score: number }> = ({\n  rank,\n  name,\n  score,\n}) => {\n  return (\n    <div\n      style={{\n        backgroundColor: COLORS.glass,\n        border: `1px solid rgba(212, 175, 55, 0.3)`,\n        borderRadius: '16px',\n        padding: '16px',\n        marginBottom: '12px',\n        display: 'flex',\n        justifyContent: 'space-between',\n        alignItems: 'center',\n        backdropFilter: 'blur(10px)',\n      }}\n    >\n      <div>\n        <div style={{ color: COLORS.gold, fontSize: '12px', fontWeight: 'bold' }}>\n          #{rank}\n        </div>\n        <div style={{ color: COLORS.white, fontSize: '14px', fontWeight: '600', marginTop: '4px' }}>\n          {name}\n        </div>\n        <div style={{ color: COLORS.textSecondary, fontSize: '11px', marginTop: '4px' }}>\n          modern • luxury • trendy\n        </div>\n      </div>\n      <div style={{ textAlign: 'center' }}>\n        <div style={{ color: COLORS.gold, fontSize: '20px', fontWeight: 'bold' }}>\n          {score}%\n        </div>\n        <div style={{ color: COLORS.textSecondary, fontSize: '10px', marginTop: '2px' }}>\n          Match\n        </div>\n      </div>\n    </div>\n  );\n};\n\nconst CompatibilityMeter: React.FC<{ label: string; score: number }> = ({ label, score }) => {\n  return (\n    <div style={{ marginBottom: '12px' }}>\n      <div\n        style={{\n          display: 'flex',\n          justifyContent: 'space-between',\n          marginBottom: '4px',\n        }}\n      >\n        <span style={{ color: COLORS.textSecondary, fontSize: '12px' }}>{label}</span>\n        <span style={{ color: COLORS.gold, fontSize: '12px', fontWeight: '600' }}>\n          {score}%\n        </span>\n      </div>\n      <div\n        style={{\n          height: '4px',\n          backgroundColor: 'rgba(255, 255, 255, 0.1)',\n          borderRadius: '2px',\n          overflow: 'hidden',\n        }}\n      >\n        <div\n          style={{\n            height: '100%',\n            width: `${score}%`,\n            backgroundColor: COLORS.gold,\n            transition: 'width 0.5s ease-out',\n          }}\n        />\n      </div>\n    </div>\n  );\n};\n\nconst PremiumButton: React.FC<{\n  text: string;\n  variant?: 'primary' | 'secondary';\n  onClick?: () => void;\n}> = ({ text, variant = 'primary', onClick }) => {\n  const isPrimary = variant === 'primary';\n\n  return (\n    <button\n      onClick={onClick}\n      style={{\n        width: '100%',\n        padding: '12px 20px',\n        borderRadius: '8px',\n        border: isPrimary ? 'none' : `1px solid ${COLORS.gold}`,\n        background: isPrimary\n          ? `linear-gradient(135deg, ${COLORS.gold}, ${COLORS.goldLight})`\n          : 'transparent',\n        color: isPrimary ? '#0a0a0a' : COLORS.gold,\n        fontWeight: '600',\n        fontSize: '14px',\n        cursor: 'pointer',\n        marginBottom: '8px',\n        transition: 'all 0.2s ease',\n      }}\n      onMouseEnter={(e) => {\n        (e.target as HTMLButtonElement).style.opacity = '0.9';\n        (e.target as HTMLButtonElement).style.transform = 'scale(1.02)';\n      }}\n      onMouseLeave={(e) => {\n        (e.target as HTMLButtonElement).style.opacity = '1';\n        (e.target as HTMLButtonElement).style.transform = 'scale(1)';\n      }}\n    >\n      {text}\n    </button>\n  );\n};\n\nexport default function WebPreview() {\n  const [activeScreen, setActiveScreen] = React.useState(0);\n\n  const screens = [\n    {\n      id: 'welcome',\n      title: 'Welcome Screen',\n      description: 'Premium onboarding introduction',\n      render: () => (\n        <MockScreen title=\"Hairstyle AI Consultant\" description=\"Welcome Screen\">\n          <div style={{ textAlign: 'center', marginBottom: '24px' }}>\n            <h1 style={{ color: COLORS.white, fontSize: '28px', margin: '0 0 12px 0' }}>\n              HAIRSTYLE AI\n            </h1>\n            <p style={{ color: COLORS.textSecondary, fontSize: '14px', lineHeight: '1.6' }}>\n              Get personalized haircut recommendations powered by advanced AI analysis. Upload a\n              selfie and receive three photorealistic previews before you ever sit in the barber's\n              chair.\n            </p>\n          </div>\n          <PremiumButton text=\"Get Started\" variant=\"primary\" />\n          <PremiumButton text=\"Learn More\" variant=\"secondary\" />\n        </MockScreen>\n      ),\n    },\n    {\n      id: 'recommendations',\n      title: 'Recommendations',\n      description: 'Three personalized hairstyle options',\n      render: () => (\n        <MockScreen title=\"Recommended Hairstyles\" description=\"Personalized for you\">\n          <StyleCard rank={1} name=\"Modern Fade + Texture\" score={98} />\n          <StyleCard rank={2} name=\"Executive Undercut\" score={92} />\n          <StyleCard rank={3} name=\"Textured Pompadour\" score={88} />\n          <PremiumButton text=\"View Details\" variant=\"primary\" />\n        </MockScreen>\n      ),\n    },\n    {\n      id: 'details',\n      title: 'Style Details',\n      description: 'Deep dive into a recommendation',\n      render: () => (\n        <MockScreen title=\"Modern Fade + Texture\" description=\"98% Match\">\n          <div style={{ marginBottom: '20px' }}>\n            <h4 style={{ color: COLORS.gold, fontSize: '12px', textTransform: 'uppercase', margin: '0 0 8px 0' }}>\n              Why This Works\n            </h4>\n            <p style={{ color: COLORS.textSecondary, fontSize: '13px', lineHeight: '1.6', margin: 0 }}>\n              This cut complements your oval face shape perfectly. The clean lines enhance your\n              strong jawline while the textured top adds dimension.\n            </p>\n          </div>\n\n          <div style={{ marginBottom: '20px' }}>\n            <h4 style={{ color: COLORS.gold, fontSize: '12px', textTransform: 'uppercase', margin: '0 0 12px 0' }}>\n              Compatibility Breakdown\n            </h4>\n            <CompatibilityMeter label=\"Face Shape\" score={98} />\n            <CompatibilityMeter label=\"Hair Texture\" score={95} />\n            <CompatibilityMeter label=\"Maintenance\" score={82} />\n            <CompatibilityMeter label=\"Professional\" score={96} />\n          </div>\n\n          <div style={{ marginBottom: '20px' }}>\n            <h4 style={{ color: COLORS.gold, fontSize: '12px', textTransform: 'uppercase', margin: '0 0 8px 0' }}>\n              Maintenance\n            </h4>\n            <div style={{ display: 'grid', gridTemplateColumns: '1fr 1fr 1fr', gap: '8px' }}>\n              <div style={{ textAlign: 'center' }}>\n                <div style={{ color: COLORS.gold, fontSize: '14px', fontWeight: 'bold' }}>Low</div>\n                <div style={{ color: COLORS.textSecondary, fontSize: '10px' }}>Level</div>\n              </div>\n              <div style={{ textAlign: 'center' }}>\n                <div style={{ color: COLORS.gold, fontSize: '14px', fontWeight: 'bold' }}>Easy</div>\n                <div style={{ color: COLORS.textSecondary, fontSize: '10px' }}>Styling</div>\n              </div>\n              <div style={{ textAlign: 'center' }}>\n                <div style={{ color: COLORS.gold, fontSize: '14px', fontWeight: 'bold' }}>6/10</div>\n                <div style={{ color: COLORS.textSecondary, fontSize: '10px' }}>Barber</div>\n              </div>\n            </div>\n          </div>\n\n          <PremiumButton text=\"View Preview\" variant=\"primary\" />\n        </MockScreen>\n      ),\n    },\n    {\n      id: 'saved',\n      title: 'Saved Looks',\n      description: 'Your personalized collection',\n      render: () => (\n        <MockScreen title=\"My Saved Looks\" description=\"Your favorite hairstyles\">\n          <div\n            style={{\n              display: 'grid',\n              gridTemplateColumns: '1fr 1fr',\n              gap: '12px',\n              marginBottom: '20px',\n            }}\n          >\n            {[1, 2, 3, 4].map((i) => (\n              <div\n                key={i}\n                style={{\n                  backgroundColor: COLORS.glass,\n                  border: `1px solid rgba(212, 175, 55, 0.3)`,\n                  borderRadius: '12px',\n                  padding: '12px',\n                  textAlign: 'center',\n                  backdropFilter: 'blur(10px)',\n                }}\n              >\n                <div\n                  style={{\n                    backgroundColor: 'rgba(212, 175, 55, 0.1)',\n                    borderRadius: '8px',\n                    height: '80px',\n                    marginBottom: '8px',\n                    display: 'flex',\n                    alignItems: 'center',\n                    justifyContent: 'center',\n                    fontSize: '24px',\n                  }}\n                >\n                  👤🧔\n                </div>\n                <div style={{ color: COLORS.gold, fontSize: '12px', fontWeight: '600' }}>\n                  {98 - i * 3}% Match\n                </div>\n              </div>\n            ))}\n          </div>\n          <PremiumButton text=\"View All\" variant=\"primary\" />\n        </MockScreen>\n      ),\n    },\n  ];\n\n  return (\n    <div\n      style={{\n        backgroundColor: COLORS.background,\n        minHeight: '100vh',\n        padding: '40px 20px',\n        fontFamily: 'system-ui, -apple-system, sans-serif',\n      }}\n    >\n      {/* Header */}\n      <div style={{ maxWidth: '1000px', margin: '0 auto', marginBottom: '40px' }}>\n        <h1 style={{ color: COLORS.gold, textAlign: 'center', fontSize: '32px', margin: '0 0 12px 0' }}>\n          ✨ Hairstyle AI Consultant\n        </h1>\n        <p\n          style={{\n            color: COLORS.textSecondary,\n            textAlign: 'center',\n            fontSize: '16px',\n            maxWidth: '600px',\n            margin: '0 auto',\n          }}\n        >\n          Premium Dark-Luxury Design Preview • Interactive UI Components • Mobile-First Responsive\n        </p>\n      </div>\n\n      {/* Mobile Preview */}\n      <div style={{ maxWidth: '450px', margin: '0 auto', marginBottom: '40px' }}>\n        {screens[activeScreen].render()}\n      </div>\n\n      {/* Navigation */}\n      <div\n        style={{\n          maxWidth: '450px',\n          margin: '0 auto',\n          display: 'grid',\n          gridTemplateColumns: 'repeat(4, 1fr)',\n          gap: '8px',\n        }}\n      >\n        {screens.map((screen, idx) => (\n          <button\n            key={screen.id}\n            onClick={() => setActiveScreen(idx)}\n            style={{\n              padding: '10px',\n              borderRadius: '8px',\n              border: idx === activeScreen ? `2px solid ${COLORS.gold}` : `1px solid rgba(255, 255, 255, 0.2)`,\n              backgroundColor: idx === activeScreen ? 'rgba(212, 175, 55, 0.1)' : 'transparent',\n              color: idx === activeScreen ? COLORS.gold : COLORS.textSecondary,\n              fontSize: '12px',\n              fontWeight: idx === activeScreen ? '600' : '400',\n              cursor: 'pointer',\n              transition: 'all 0.2s ease',\n            }}\n            onMouseEnter={(e) => {\n              (e.target as HTMLButtonElement).style.borderColor = COLORS.gold;\n              (e.target as HTMLButtonElement).style.color = COLORS.gold;\n            }}\n            onMouseLeave={(e) => {\n              if (idx !== activeScreen) {\n                (e.target as HTMLButtonElement).style.borderColor = 'rgba(255, 255, 255, 0.2)';\n                (e.target as HTMLButtonElement).style.color = COLORS.textSecondary;\n              }\n            }}\n          >\n            {screen.title}\n          </button>\n        ))}\n      </div>\n\n      {/* Features */}\n      <div\n        style={{\n          maxWidth: '1000px',\n          margin: '60px auto 0',\n          display: 'grid',\n          gridTemplateColumns: 'repeat(auto-fit, minmax(250px, 1fr))',\n          gap: '20px',\n        }}\n      >\n        {[\n          { icon: '📸', title: 'Selfie Upload', desc: 'High-quality photo analysis' },\n          { icon: '🧠', title: 'AI Analysis', desc: 'Gemini 2.5 Flash facial detection' },\n          { icon: '✨', title: 'Previews', desc: 'Photorealistic hairstyle renders' },\n          { icon: '📊', title: 'Scoring', desc: 'Detailed compatibility metrics' },\n          { icon: '💾', title: 'Save Looks', desc: 'MongoDB persistence' },\n          { icon: '🎨', title: 'Premium Design', desc: 'Dark-luxury glassmorphism' },\n        ].map((feature, idx) => (\n          <div\n            key={idx}\n            style={{\n              backgroundColor: COLORS.glass,\n              border: `1px solid rgba(212, 175, 55, 0.2)`,\n              borderRadius: '12px',\n              padding: '20px',\n              textAlign: 'center',\n              backdropFilter: 'blur(10px)',\n            }}\n          >\n            <div style={{ fontSize: '32px', marginBottom: '12px' }}>{feature.icon}</div>\n            <h3 style={{ color: COLORS.gold, fontSize: '14px', margin: '0 0 8px 0' }}>\n              {feature.title}\n            </h3>\n            <p style={{ color: COLORS.textSecondary, fontSize: '12px', margin: 0 }}>\n              {feature.desc}\n            </p>\n          </div>\n        ))}\n      </div>\n\n      {/* Footer */}\n      <div\n        style={{\n          textAlign: 'center',\n          marginTop: '60px',\n          paddingTop: '20px',\n          borderTop: `1px solid rgba(255, 255, 255, 0.1)`,\n          color: COLORS.textSecondary,\n          fontSize: '12px',\n        }}\n      >\n        <p>\n          Built with ❤️ • Expo + TypeScript + Gemini + BananaML + MongoDB\n          <br />\n          <a\n            href=\"https://github.com/aayav/hairstyle-ai-consultant\"\n            style={{\n              color: COLORS.gold,\n              textDecoration: 'none',\n            }}\n            onMouseEnter={(e) => {\n              (e.target as HTMLAnchorElement).style.textDecoration = 'underline';\n            }}\n            onMouseLeave={(e) => {\n              (e.target as HTMLAnchorElement).style.textDecoration = 'none';\n            }}\n          >\n            View on GitHub →\n          </a>\n        </p>\n      </div>\n    </div>\n  );\n}\n", "path": "web-preview/src/App.tsx"}, {"content": "import React from 'react';\nimport ReactDOM from 'react-dom/client';\nimport App from './App';\n\nReactDOM.createRoot(document.getElementById('root')!).render(\n  <React.StrictMode>\n    <App />\n  </React.StrictMode>\n);\n", "path": "web-preview/src/main.tsx"}, {"content": "<!doctype html>\n<html lang=\"en\">\n  <head>\n    <meta charset=\"UTF-8\" />\n    <link rel=\"icon\" type=\"image/svg+xml\" href=\"data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='75' font-size='75' fill='%23d4af37'>✨</text></svg>\" />\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n    <title>Hairstyle AI Consultant - Premium Design Preview</title>\n    <style>\n      * {\n        margin: 0;\n        padding: 0;\n        box-sizing: border-box;\n      }\n      \n      html, body {\n        background: #0a0a0a;\n        color: #ffffff;\n        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', 'Ubuntu',\n          'Cantarell', 'Fira Sans', 'Droid Sans', 'Helvetica Neue', sans-serif;\n        -webkit-font-smoothing: antialiased;\n        -moz-osx-font-smoothing: grayscale;\n      }\n      \n      #root {\n        width: 100%;\n        min-height: 100vh;\n      }\n      \n      button {\n        font-family: inherit;\n      }\n      \n      a {\n        color: #d4af37;\n      }\n    </style>\n  </head>\n  <body>\n    <div id=\"root\"></div>\n    <script type=\"module\" src=\"/src/main.tsx\"></script>\n  </body>\n</html>\n", "path": "web-preview/index.html"}, {"content": "import { defineConfig } from 'vite';\nimport react from '@vitejs/plugin-react';\n\nexport default defineConfig({\n  plugins: [react()],\n  base: '/hairstyle-ai-consultant/',\n  build: {\n    outDir: '../docs',\n    emptyOutDir: true,\n  },\n});\n", "path": "web-preview/vite.config.ts"}]